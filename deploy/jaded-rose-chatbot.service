[Unit]
Description=Jaded Rose Chatbot (FastAPI + Telegram)
After=network.target

[Service]
Type=simple
User=cohiba
WorkingDirectory=/home/cohiba/02_jaded-rose-chatbot
EnvironmentFile=/home/cohiba/02_jaded-rose-chatbot/.env
ExecStart=/home/cohiba/02_jaded-rose-chatbot/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
