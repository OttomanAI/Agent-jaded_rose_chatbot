# ─── Jaded Rose Chatbot — Environment Variables ─────────────────────────
# Copy this file to .env and fill in your real values.

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token           # From @BotFather

# ── Twilio / WhatsApp ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid           # Twilio Console → Dashboard
TWILIO_AUTH_TOKEN=your-twilio-auth-token              # Twilio Console → Dashboard
WHATSAPP_FROM_NUMBER=+14155238886                     # Your Twilio WhatsApp sender number

# ── Gmail ─────────────────────────────────────────────────────────────────
GMAIL_CREDENTIALS_JSON=credentials.json               # Path to Google OAuth credentials file
GMAIL_SUPPORT_ADDRESS=support@jadedrose.com           # The support inbox to monitor

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key                 # OpenAI API key (GPT-4o + embeddings)

# ── Pinecone ──────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key                # Pinecone console → API Keys
PINECONE_INDEX=jaded-rose                             # Name of the Pinecone index

# ── Shopify ───────────────────────────────────────────────────────────────
SHOPIFY_STORE_URL=https://jaded-rose.myshopify.com    # Your Shopify store URL
SHOPIFY_ADMIN_API_KEY=shpat_your-admin-api-key        # Shopify Admin API access token

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0                    # Redis connection string (conversation memory)

# ── Escalation ────────────────────────────────────────────────────────────
ESCALATION_EMAIL=team@jadedrose.com                   # Email address for human escalation alerts

# ── Carrier API Keys ─────────────────────────────────────────────────────
ROYAL_MAIL_API_KEY=your-royal-mail-api-key            # Royal Mail Tracking API
DHL_API_KEY=your-dhl-api-key                          # DHL Shipment Tracking API v2
DPD_API_KEY=your-dpd-api-key                          # DPD Tracking API
